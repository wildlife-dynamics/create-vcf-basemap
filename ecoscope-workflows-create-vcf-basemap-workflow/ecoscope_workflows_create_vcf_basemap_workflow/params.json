{
  "properties": {
    "workflow_details": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "title": "Workflow Name",
          "type": "string"
        },
        "description": {
          "default": "",
          "title": "Workflow Description",
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "type": "object",
      "description": "Add information that will help to differentiate this workflow from another.",
      "title": "Workflow Details"
    },
    "gee_conn": {
      "additionalProperties": false,
      "properties": {
        "data_source": {
          "$ref": "#/$defs/GoogleEarthEngineConnection",
          "title": "",
          "description": "Select one of your configured data sources."
        }
      },
      "required": [
        "data_source"
      ],
      "type": "object",
      "title": "GEE Connection"
    },
    "roi": {
      "additionalProperties": false,
      "properties": {
        "config": {
          "anyOf": [
            {
              "$ref": "#/$defs/LocalFileSpatialFeatures"
            },
            {
              "$ref": "#/$defs/RemoteFileSpatialFeatures"
            },
            {
              "$ref": "#/$defs/EarthRangerSpatialFeatures"
            }
          ],
          "title": "Spatial Feature Data Source"
        }
      },
      "required": [
        "config"
      ],
      "type": "object",
      "title": "Load Region of Interest"
    },
    "vcf_palette": {
      "additionalProperties": false,
      "properties": {
        "bare_hex": {
          "default": "B89070",
          "pattern": "^#?[0-9A-Fa-f]{6}$",
          "title": "Bare Hex",
          "type": "string"
        },
        "herb_hex": {
          "default": "B3B2A0",
          "pattern": "^#?[0-9A-Fa-f]{6}$",
          "title": "Herb Hex",
          "type": "string"
        },
        "tree_hex": {
          "default": "4F7B47",
          "pattern": "^#?[0-9A-Fa-f]{6}$",
          "title": "Tree Hex",
          "type": "string"
        },
        "water_hex": {
          "default": "4A7BA8",
          "pattern": "^#?[0-9A-Fa-f]{6}$",
          "title": "Water Hex",
          "type": "string"
        },
        "ocean_hex": {
          "default": "2A5A82",
          "pattern": "^#?[0-9A-Fa-f]{6}$",
          "title": "Ocean Hex",
          "type": "string"
        },
        "water_occurrence_min": {
          "default": 50,
          "maximum": 100,
          "minimum": 0,
          "title": "Water Occurrence Min",
          "type": "integer"
        }
      },
      "type": "object",
      "required": [],
      "title": "Endmember Palette"
    },
    "vcf_export": {
      "additionalProperties": false,
      "properties": {
        "year": {
          "default": 2020,
          "maximum": 2024,
          "minimum": 2000,
          "title": "Year",
          "type": "integer"
        },
        "scale_m": {
          "default": 250,
          "maximum": 5000,
          "minimum": 250,
          "title": "Scale M",
          "type": "integer"
        },
        "hillshade_weight": {
          "default": 0.6,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Hillshade Weight",
          "type": "number"
        },
        "output_name": {
          "default": "vcf_hillshade_basemap",
          "title": "Output Name",
          "type": "string"
        }
      },
      "required": [],
      "type": "object",
      "title": "Download Basemap GeoTIFF"
    },
    "vcf_preview": {
      "additionalProperties": false,
      "properties": {
        "year": {
          "default": 2020,
          "maximum": 2024,
          "minimum": 2000,
          "title": "Year",
          "type": "integer"
        },
        "hillshade_weight": {
          "default": 0.6,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Hillshade Weight",
          "type": "number"
        }
      },
      "required": [],
      "type": "object",
      "title": "Preview Basemap"
    }
  },
  "$defs": {
    "GoogleEarthEngineConnection": {
      "properties": {
        "name": {
          "title": "Data Source",
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "title": "GoogleEarthEngineConnection",
      "type": "object"
    },
    "EarthRangerSpatialFeatures": {
      "properties": {
        "data_source": {
          "description": "Select one of your configured EarthRanger data sources.",
          "title": "Data Source",
          "type": "string"
        },
        "spatial_features_group_name": {
          "description": "Name of the spatial features group in EarthRanger",
          "title": "Spatial Features Group Name",
          "type": "string"
        }
      },
      "required": [
        "data_source",
        "spatial_features_group_name"
      ],
      "title": "EarthRanger",
      "type": "object"
    },
    "LocalFileSpatialFeatures": {
      "properties": {
        "file_path": {
          "description": "Path to geoparquet (.parquet) or geopackage (.gpkg) file",
          "title": "File Path",
          "type": "string"
        },
        "name_column": {
          "description": "Column to use as region name",
          "title": "Name Column",
          "type": "string"
        },
        "layer": {
          "default": null,
          "description": "Layer name (only applicable to geopackage files)",
          "ecoscope:advanced": true,
          "title": "Layer",
          "type": ["string", "null"]
        }
      },
      "required": [
        "file_path",
        "name_column"
      ],
      "title": "Local File",
      "type": "object"
    },
    "RemoteFileSpatialFeatures": {
      "properties": {
        "url": {
          "description": "URL to geoparquet (.parquet) or geopackage (.gpkg) file",
          "title": "Url",
          "type": "string"
        },
        "name_column": {
          "description": "Column to use as region name",
          "title": "Name Column",
          "type": "string"
        },
        "layer": {
          "default": null,
          "description": "Layer name (only applicable for geopackage files)",
          "ecoscope:advanced": true,
          "title": "Layer",
          "type": ["string", "null"]
        }
      },
      "required": [
        "url",
        "name_column"
      ],
      "title": "Remote URL",
      "type": "object"
    }
  },
  "uiSchema": {
    "workflow_details": {
      "ui:order": [
        "name",
        "description"
      ]
    },
    "vcf_palette": {
      "ui:order": [
        "bare_hex",
        "herb_hex",
        "tree_hex",
        "water_hex",
        "ocean_hex",
        "water_occurrence_min"
      ]
    },
    "vcf_export": {
      "ui:order": [
        "year",
        "scale_m",
        "hillshade_weight",
        "output_name"
      ]
    },
    "vcf_preview": {
      "ui:order": [
        "year",
        "hillshade_weight"
      ]
    },
    "ui:order": [
      "workflow_details",
      "gee_conn",
      "roi",
      "vcf_palette",
      "vcf_export",
      "vcf_preview"
    ]
  },
  "additionalProperties": false
}
