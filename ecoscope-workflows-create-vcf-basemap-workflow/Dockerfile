# AUTOGENERATED BY ECOSCOPE-WORKFLOWS; see fingerprint in README.md for details


FROM bitnami/minideb:bullseye AS fetch
RUN apt-get update && apt-get install -y curl ca-certificates
RUN curl -fsSL https://pixi.sh/install.sh | PIXI_VERSION=latest bash

FROM bitnami/minideb:bullseye AS install
COPY --from=fetch /root/.pixi /root/.pixi
COPY --from=fetch /etc/ssl/certs/ca-certificates.crt /etc/ssl/certs/ca-certificates.crt
ENV PATH="/root/.pixi/bin:$PATH"

# Path to the repo root on the BUILD HOST (passed at build time so the
# container can rewrite any absolute host paths in pixi.toml / pixi.lock
# to the container's WORKDIR /app, where the repo is COPY'd to).
ARG VCFBASEMAP_WORKSPACE_PATH=/Users/la/vcf/create-vcf-basemap

WORKDIR /app
COPY . .
# Replace absolute host path with /app so pixi can find the local vcf-basemap
# editable package (which lives at the repo root, now at /app inside the image).
RUN find . -maxdepth 3 \( -name "pixi.toml" -o -name "pixi.lock" \) \
    -exec sed -i "s|${VCFBASEMAP_WORKSPACE_PATH}|/app|g" {} \;
RUN pixi install --manifest-path ecoscope-workflows-create-vcf-basemap-workflow/pixi.toml \
    -e default -e runner --frozen

FROM install AS app
ENV PORT 8080
ENV CONCURRENCY 1
ENV UVICORN_TIMEOUT 600
CMD WT_INVOKERS__RESULTS_ENV_VAR=ECOSCOPE_WORKFLOWS_RESULTS \
    ECOSCOPE_WORKFLOWS_MATCHSPEC_OVERRIDE=ecoscope-workflows-create-vcf-basemap-workflow \
    WT_INVOKERS__LOCAL_SUBPROCESS_INVOKER__CWD=/app/ecoscope-workflows-create-vcf-basemap-workflow \
    pixi run --manifest-path ecoscope-workflows-create-vcf-basemap-workflow/pixi.toml -e runner \
    uvicorn --host 0.0.0.0 --port $PORT --workers $CONCURRENCY --timeout-graceful-shutdown $UVICORN_TIMEOUT wt_runner.app:app
